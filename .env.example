# ─── Server ────────────────────────────────────────────
NODE_ENV=development

# ─── JWT Authentication ────────────────────────────────
JWT_SECRET=change-this-to-a-strong-random-secret-key

# ─── Azure Cosmos DB ───────────────────────────────────
COSMOS_ENDPOINT=https://your-account.documents.azure.com:443/
COSMOS_KEY=your-cosmos-primary-key
COSMOS_DATABASE=mediashare

# ─── Azure Blob Storage ───────────────────────────────
STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=youraccount;AccountKey=yourkey;EndpointSuffix=core.windows.net
STORAGE_CONTAINER_NAME=media

# ─── Azure AI Vision (Image Analysis 4.0) ─────────────
VISION_ENDPOINT=https://your-region.api.cognitive.microsoft.com/
VISION_KEY=your-vision-api-key

# ─── Azure AI Content Safety ──────────────────────────
CONTENT_SAFETY_ENDPOINT=https://your-region.cognitiveservices.azure.com/
CONTENT_SAFETY_KEY=your-content-safety-key
